    /**
     * 基于分集大纲生成完整剧本
     */
    async generateFullScript(project, outline, onProgress = null) {
        if (!this.isAvailable()) {
            throw new Error('AI服务未配置，请先设置API Key');
        }

        const fullScript = [];
        const totalEpisodes = outline.length;

        // 逐集生成，确保每集质量
        for (let i = 0; i < totalEpisodes; i++) {
            const episode = outline[i];
            console.log(`正在生成第${episode.episodeNumber}集剧本...`);

            try {
                // 准备前一集的上下文（用于连续性）
                let previousEpisodeSummary = '';
                if (i > 0) {
                    const prevEp = outline[i - 1];
                    const prevContent = prevEp.content || '';

                    // 内联：提取情感状态
                    let emotionalState = 'Neutral';
                    if (prevContent.includes('愤怒') || prevContent.includes('angry')) emotionalState = 'Angry';
                    else if (prevContent.includes('伤心') || prevContent.includes('sad')) emotionalState = 'Heartbroken';
                    else if (prevContent.includes('开心') || prevContent.includes('happy')) emotionalState = 'Happy';
                    else if (prevContent.includes('爱意') || prevContent.includes('love')) emotionalState = 'Loving';
                    else if (prevContent.includes('嫉妒') || prevContent.includes('jealous')) emotionalState = 'Jealous';

                    // 内联：提取关系状态
                    let relationshipStatus = 'Neutral';
                    if (prevContent.includes('亲密') || prevContent.includes('kiss')) relationshipStatus = 'Growing closer';
                    else if (prevContent.includes('误会') || prevContent.includes('争吵')) relationshipStatus = 'Conflict/Tension';
                    else if (prevContent.includes('陌生') || prevContent.includes('冷漠')) relationshipStatus = 'Distant';
                    else if (prevContent.includes('合作') || prevContent.includes('和好')) relationshipStatus = 'Cooperative';

                    previousEpisodeSummary = `
Previous Episode (${prevEp.episodeNumber}) Summary:
- Title: ${prevEp.title}
- What happened: ${prevEp.content?.substring(0, 300) || 'N/A'}...
- Emotional state at end: ${emotionalState}
- Characters' relationship status: ${relationshipStatus}
                    `.trim();
                } else {
                    previousEpisodeSummary = 'This is the first episode. No previous context needed.';
                }

                const scriptEpisode = await this.generateEpisodeScript(
                    project,
                    episode,
                    i + 1,
                    totalEpisodes,
                    previousEpisodeSummary
                );
                fullScript.push(scriptEpisode);

                // 更新进度
                if (onProgress) {
                    onProgress(i + 1, totalEpisodes);
                }

                // 添加小延迟，避免请求过快
                if (i < totalEpisodes - 1) {
                    await new Promise(resolve => setTimeout(resolve, 1000));
                }

            } catch (error) {
                console.error(`第${episode.episodeNumber}集生成失败:`, error);
                // 如果某集失败，添加占位符继续
                fullScript.push({
                    episodeNumber: episode.episodeNumber,
                    title: episode.title,
                    content: '[该集剧本生成失败，请重新生成]',
                    error: true
                });
            }
        }

        return fullScript;
    }

    /**
     * 生成单集详细剧本
     */
    async generateEpisodeScript(project, episode, currentNum, totalNum, previousEpisodeSummary = '') {
        const { title, typeInfo, creative, characters } = project;
        const category = typeInfo.category;

        // 获取所有角色信息（6个角色体系）
        const protag = characters.find(c => c.role === 'protagonist');
        const love = characters.find(c => c.role === 'love-interest');
        const antag = characters.find(c => c.role === 'antagonist');
        const antag2 = characters.find(c => c.role === 'antagonist2');
        const supporting = characters.find(c => c.role === 'supporting');
        const supporting2 = characters.find(c => c.role === 'supporting2');

        // 构建角色列表
        let characterList = `- Protagonist: ${protag?.name || 'Sophia'}
- ${category === 'female' ? 'Male Lead' : 'Female Lead'}: ${love?.name || 'Alexander'}
- Primary Antagonist: ${antag?.name || 'Victoria'}`;

        if (antag2) {
