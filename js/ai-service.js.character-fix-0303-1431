    }

    /**
     * 解析AI响应为结构化数据
     */
    parseOutline(aiText, totalEpisodes) {
        const episodes = [];
        const lines = aiText.split('\n').filter(line => line.trim());

        let currentEpisode = null;

        for (const line of lines) {
            // 匹配集数标题：支持中英文格式
            // 中文：第1集：《标题》 或 第1集《标题》 或 第1集
            // 英文：Episode 1: "Title" 或 Episode 1 - Title 或 Episode 1
            const episodeMatch = line.match(/第\s*(\d+)\s*集[:：]《?([^》]+)》?/) ||
                                 line.match(/Episode\s+(\d+)[:\-\s]+["《]?([^"》]+)["》]?/i);

            if (episodeMatch) {
                // 保存上一集
                if (currentEpisode) {
                    episodes.push(currentEpisode);
                }

                const epNum = parseInt(episodeMatch[1]);
                currentEpisode = {
                    episodeNumber: epNum,
                    title: episodeMatch[2]?.trim() || `第${epNum}集`,
                    content: '',
                    hook: '',
                    act: this.getActByEpisode(epNum, totalEpisodes),
                    isTwist: false,
                    isClimax: epNum === totalEpisodes,
                    isFirst: epNum === 1,
                    isFinal: epNum === totalEpisodes,
                    estimatedDuration: 90
                };
            } else if (currentEpisode) {
                // 解析其他字段 - 支持中英文
                const lowerLine = line.toLowerCase();

                if (lowerLine.includes('plot:') || lowerLine.includes('剧情') || lowerLine.includes('plot：')) {
                    currentEpisode.content += line.replace(/.*[:：]/, '').trim() + '\n';
                } else if (lowerLine.includes('hook:') || lowerLine.includes('钩子') || lowerLine.includes('hook：')) {
                    currentEpisode.hook = line.replace(/.*[:：]/, '').trim();
                } else if (lowerLine.includes('twist:') || lowerLine.includes('highlight:') ||
                          lowerLine.includes('爽点') || lowerLine.includes('虐点') || lowerLine.includes('反转')) {
                    currentEpisode.content += '[' + line.trim() + ']\n';
                } else if (lowerLine.includes('setting:') || lowerLine.includes('场景') || lowerLine.includes('setting：')) {
                    currentEpisode.content += '[Setting: ' + line.replace(/.*[:：]/, '').trim() + ']\n';
                } else if (lowerLine.includes('duration:') || lowerLine.includes('时长') || lowerLine.includes('duration：')) {
                    const duration = line.match(/(\d+)/);
                    if (duration) {
                        currentEpisode.estimatedDuration = parseInt(duration[1]);
                    }
                } else {
                    currentEpisode.content += line + '\n';
                }
            }
        }

        // 添加最后一集
        if (currentEpisode) {
            episodes.push(currentEpisode);
        }

        // 标记反转集
        episodes.forEach((ep, index) => {
            if (index > 0 && index < episodes.length - 1) {
                if (ep.content.includes('反转') || ep.content.includes('真相') || ep.content.includes('暴露') ||
                    ep.content.toLowerCase().includes('twist') || ep.content.toLowerCase().includes('reveal')) {
                    ep.isTwist = true;
                }
            }
        });

        // 安全检查：是否生成足够的集数
        if (episodes.length < totalEpisodes) {
            console.warn(`警告: AI只生成了${episodes.length}集，需要${totalEpisodes}集。建议重新生成。`);
            // 自动补充缺失的集数（用占位符）
            for (let i = episodes.length + 1; i <= totalEpisodes; i++) {
                episodes.push({
                    episodeNumber: i,
                    title: `Episode ${i}`,
                    content: '[Content missing - please regenerate]',
                    hook: 'To be continued...',
                    act: this.getActByEpisode(i, totalEpisodes),
                    isTwist: false,
                    isClimax: i === totalEpisodes,
                    isFirst: i === 1,
                    isFinal: i === totalEpisodes,
                    estimatedDuration: 90
                });
            }
        }

        return episodes;
    }

    /**
     * 根据集数确定幕
     */
    getActByEpisode(epNum, total) {
        if (epNum <= total * 0.2) return 'act1';
        if (epNum <= total * 0.6) return 'act2';
        if (epNum <= total * 0.85) return 'act3';
        return 'act4';
    }

