    /**
     * 解析AI生成的人物设定
     */
    parseCharacterResponse(aiText, category) {
        const characters = [];

        // 预处理：标准化换行符，移除BOM和特殊空格
        const normalizedText = aiText
            .replace(/\r\n/g, '\n')
            .replace(/\r/g, '\n')
            .replace(/^\uFEFF/, '')
            .replace(/[\u00A0\u3000]/g, ' ');

        console.log('[角色解析] 原始文本长度:', aiText.length);
        console.log('[角色解析] 标准化后长度:', normalizedText.length);
        console.log('[角色解析] 前200字符:', normalizedText.substring(0, 200));

        // 改进分割逻辑，支持多种格式
        let sections = normalizedText.split(/角色：|Character:/i).filter(s => s.trim());

        // 如果分割后只有1个或没有，尝试用数字+点号的格式（如"1. "或"1."）
        if (sections.length <= 1) {
            // 尝试匹配 "1. 角色名" 或 "1.角色名" 格式
            sections = aiText.split(/\n\d+[\.\．]\s*/).filter(s => s.trim());
        }

        // 如果还是只有1个，尝试用换行+数字+空格
        if (sections.length <= 1) {
            sections = aiText.split(/\n(?=\d+\s+[\u4e00-\u9fa5])/).filter(s => s.trim());
        }

        console.log('解析到的角色段落数:', sections.length);
        console.log('角色内容预览:', sections.map((s, i) => `${i}: ${s.substring(0, 50)}...`));

        const roles = ['protagonist', 'love-interest', 'antagonist', 'antagonist2', 'supporting', 'supporting2'];

        // ⚠️ 关键修复：确保sections长度足够，且第一个section不为空
        if (sections.length === 0) {
            console.warn('角色解析失败：没有分割到任何角色段落，使用默认角色');
            return this.getDefaultCharacters(category);
        }

        // 如果第一个section看起来像完整的AI响应（包含所有角色），尝试进一步分割
        if (sections.length < 6 && sections.length > 0) {
            const firstSection = sections[0];
            // 尝试用"角色："重新分割（可能整个响应都在第一个section里）
            const reSplit = firstSection.split(/角色：/);
            if (reSplit.length > 2) {
                console.log('检测到所有角色都在第一个段落中，重新分割');
                sections = reSplit.filter(s => s.trim());
            }
        }

        // 常见的女性名字和男性名字（用于验证和替换）
        const femaleNames = ['Sophia', 'Emma', 'Olivia', 'Ava', 'Isabella', 'Mia', 'Charlotte', 'Amelia', 'Evelyn', 'Abigail', 'Grace', 'Emily'];
        const maleNames = ['Alexander', 'Ethan', 'Michael', 'James', 'William', 'Benjamin', 'Lucas', 'Henry', 'Daniel', 'Matthew', 'Jackson', 'Sebastian'];

        // 占位符名称检测
        const placeholderNames = ['女主角', '男主角', '女主', '男主', '女主人公', '男主人公', '主角', '恋爱对象'];

        // 关键修复：过滤掉非角色段落（如AI的说明文字）
        const validSections = sections.filter(section => {
            const firstLine = section.split('\n')[0]?.trim();
            // 保留以名字开头或包含角色标识符的段落
            return firstLine && (
                firstLine.match(/^[A-Z][a-z]+/) || // 英文名字
                firstLine.match(/^[一-龥]{2,4}/) || // 中文名字
                section.match(/身份|Role|Status|年龄|Age/i) // 包含角色字段
            );
        });

        console.log(`[角色解析] 有效角色段落: ${validSections.length}/${sections.length}`);

        // 如果过滤后没有有效段落，直接返回默认角色
        if (validSections.length === 0) {
            console.error('[角色解析] 没有有效的角色段落，使用默认角色');
            return this.getDefaultCharacters(category);
        }

        validSections.forEach((section, index) => {
            if (index >= roles.length) return;

            const lines = section.split('\n').filter(l => l.trim());
            console.log(`[角色解析] 第${index+1}个角色: 段落行数=${lines.length}`);

            // 提取名字：尝试第一行，如果没有则使用默认
            let name = '';
            if (lines.length > 0) {
                const nameLine = lines[0];
                console.log(`[角色解析] 第${index+1}个角色原始名称行: "${nameLine}"`);

                // 移除常见的前缀如"1. "、"主角："等
                const cleanLine = nameLine.replace(/^\d+[\.\．\、]\s*/, '').replace(/^(主角|角色|恋爱对象)[：:]\s*/, '');
                name = cleanLine.split(/[（(]/)[0].trim();
                console.log(`[角色解析] 第${index+1}个角色提取名称: "${name}"`);
            }

            // 验证名字有效性
            if (!name || name.length < 2 || placeholderNames.some(p => name.includes(p))) {
                console.warn(`[角色解析] 第${index+1}个角色名字无效("${name}"), 使用默认名字`);
                name = index === 0 ?
                    (category === 'female' ? femaleNames[0] : maleNames[0]) :
                    index === 1 ?
                        (category === 'female' ? maleNames[1] : femaleNames[1]) :
                        femaleNames[index] || maleNames[index];
            }

            // 提取各种属性
