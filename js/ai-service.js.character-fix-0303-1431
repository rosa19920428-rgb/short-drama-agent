    /**
     * 强制使用正确的角色名字（后处理）
     */
    enforceCharacterNames(content, characters) {
        // 常见的中文名字模式（如果AI错误地使用了中文名，替换为英文名）
        const protag = characters.find(c => c.role === 'protagonist');
        const love = characters.find(c => c.role === 'love-interest');
        const antag = characters.find(c => c.role === 'antagonist');

        // 如果内容中包含典型的中文名字（2-3个汉字），尝试替换
        // 这里使用简单的启发式方法：如果名字不在我们的角色列表中，可能是AI自创的中文名
        const characterNames = characters.map(c => c.name).filter(name => name && name.length > 0);

        // 检查每一行对话的角色名
        const lines = content.split('\n');
        const processedLines = lines.map(line => {
            // 匹配大写的角色名（剧本格式）
            const charMatch = line.match(/^([A-Z][A-Z\s]*)$/);
            if (charMatch) {
                const name = charMatch[1].trim();
                // 如果这个名字不在我们的角色列表中，且看起来像中文（包含非英文字符）
                if (!characterNames.some(cn => cn.toUpperCase() === name) && /[^\x00-\x7F]/.test(name)) {
                    // 根据上下文替换为最接近的角色
                    // 简单策略：第一幕通常是主角，第二幕是恋爱对象，第三幕是反派
                    return protag ? protag.name.toUpperCase() : name;
                }
            }
            return line;
        });

        return processedLines.join('\n');
    }

    /**
     * 从大纲内容中提取场景信息
     */
    extractSetting(content) {
        if (!content) return 'TBD';
        const settingMatch = content.match(/\[场景:\s*(.+?)\]/);
        return settingMatch ? settingMatch[1] : 'Various locations';
    }
