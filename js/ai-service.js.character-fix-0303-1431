        const response = await fetch(this.API_URL, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${this.API_KEY}`,
                'HTTP-Referer': window.location.href,
                'X-Title': 'Short Drama Script Agent'
            },
            body: JSON.stringify({
                model: this.MODEL,
                messages: [
                    {
                        role: 'system',
                        content: `You are a professional Hollywood screenwriter specializing in short-form vertical dramas. You write in standard Hollywood screenplay format with sharp dialogue and strong visual storytelling.`
                    },
                    {
                        role: 'user',
