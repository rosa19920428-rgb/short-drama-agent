                    appearance: category === 'female' ? '深色短发，锐利蓝眼睛，总是穿着定制西装' : '金色长发，优雅气质，时尚穿着',
                    personality: category === 'female' ? '表面冷酷，内心温柔，有保护欲' : '独立自信，聪明机智',
                    background: category === 'female' ? '白手起家创建商业帝国' : '事业有成的职业女性',
                    motivation: category === 'female' ? '找到真爱，同时保护公司' : '追求真爱，平衡事业与感情',
                    secret: category === 'female' ? '早就注意到主角的特别' : '对主角一见钟情但不敢表白'
                }
            },
            {
