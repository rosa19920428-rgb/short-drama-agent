    /**
     * 解析AI返回的创意内容
     */
    parseCreativeIdeas(content) {
        const ideas = [];

        // 将内容按行分割
        const lines = content.split('\n');
        let currentIdea = null;

        for (let i = 0; i < lines.length; i++) {
            const line = lines[i].trim();

            // 检查是否是新的创意开始
            // 匹配：创意1：、创意 1：、1. 等格式
            const ideaStartMatch = line.match(/^(?:创意\s*(\d+)[：:]?|(\d+)[\.\、])[\s\-–•\*]*(.*)$/i);

            if (ideaStartMatch) {
                // 保存之前的创意
                if (currentIdea) {
                    ideas.push(currentIdea);
                }

                // 创建新创意
                currentIdea = {
                    title: '',
                    concept: '',
                    synopsis: ''
                };

                // 如果这一行后面还有内容（如"创意1：标题"），提取为标题
                const remainder = ideaStartMatch[3]?.trim();
                if (remainder) {
                    // 如果包含"标题："，提取后面的内容
                    const titleMatch = remainder.match(/^标题[：:]\s*(.+)/i);
                    if (titleMatch) {
                        currentIdea.title = titleMatch[1].trim();
                    } else {
                        currentIdea.title = remainder;
                    }
                }

                continue;
            }

            // 如果没有当前创意，跳过
            if (!currentIdea) continue;

            // 匹配标题行
            const titleMatch = line.match(/^标题[：:]\s*(.+)/i);
            if (titleMatch) {
                currentIdea.title = titleMatch[1].trim();
                continue;
            }

            // 匹配概念行
            const conceptMatch = line.match(/^概念[：:]\s*(.+)/i);
            if (conceptMatch) {
                currentIdea.concept = conceptMatch[1].trim();
                continue;
            }

            // 匹配梗概行（开始）
            const synopsisMatch = line.match(/^梗概[：:]\s*(.+)/i);
            if (synopsisMatch) {
                currentIdea.synopsis = synopsisMatch[1].trim();
                currentIdea._parsingSynopsis = true; // 标记正在解析梗概
                continue;
            }

            // 匹配外在期待（核心期待 - 外在事件）
            const externalHookMatch = line.match(/^(?:外在期待|外在钩子|核心期待|外在事件)[：:]\s*(.+)/i);
            if (externalHookMatch) {
                currentIdea.externalHook = externalHookMatch[1].trim();
                currentIdea.hook = currentIdea.externalHook; // 兼容旧字段
                currentIdea._parsingSynopsis = false; // 结束梗概解析
                continue;
            }

            // 匹配内在期待（核心期待 - 内在情感）
            const internalHookMatch = line.match(/^(?:内在期待|内在钩子|情感钩子|内在情感)[：:]\s*(.+)/i);
            if (internalHookMatch) {
                currentIdea.internalHook = internalHookMatch[1].trim();
                currentIdea._parsingSynopsis = false; // 结束梗概解析
                continue;
            }

            // 如果正在解析梗概，且当前行不是新字段的开始，则追加到梗概
            if (currentIdea?._parsingSynopsis && line) {
                // 检查是否是下一个创意的开始（必须在追加前检查）
                if (line.match(/^(?:创意\s*\d+|\d+[\.\、])[：:]/i)) {
                    currentIdea._parsingSynopsis = false;
                    // 不追加这一行，让外层循环处理下一个创意
                } else if (!line.match(/^(标题|概念|外在|内在)[：:]/i)) {
                    // 只有不是其他字段时，才追加到梗概
                    currentIdea.synopsis += ' ' + line;
                }
            }
        }

        // 保存最后一个创意
        if (currentIdea) {
            ideas.push(currentIdea);
        }

        console.log(`[创意解析] 原始解析数量: ${ideas.length}`);
        console.log(`[创意解析] 各创意标题:`, ideas.map((i, idx) => `${idx+1}. ${i.title || '(空)'}`));

        // 过滤掉空创意并确保每个创意有默认值
        const validIdeas = ideas.filter(idea => {
            const hasContent = idea.title || idea.concept;
            if (!hasContent) {
                console.log(`[创意解析] 过滤掉空创意:`, idea);
            }
            return hasContent;
        }).map((idea, index) => {
            // 基于创意内容生成智能默认钩子
            const isContractMarriage = idea.synopsis?.includes('契约') || idea.synopsis?.includes('合同') || idea.concept?.includes('契约');
            const isIdentityHide = idea.synopsis?.includes('身份') || idea.synopsis?.includes('隐瞒') || idea.concept?.includes('身份');
            const isRevenge = idea.synopsis?.includes('复仇') || idea.concept?.includes('复仇');
            const isCinderella = idea.synopsis?.includes('平凡') || idea.synopsis?.includes('普通') || idea.concept?.includes('平凡');

            let defaultExternal = '悬念待揭晓';
            let defaultInternal = '情感发展待展开';

            if (isContractMarriage) {
                defaultExternal = '契约关系何时被揭穿/何时到期';
                defaultInternal = '契约双方何时真正爱上对方而非演戏';
            } else if (isIdentityHide) {
                defaultExternal = '男主角的真实身份何时被女主角发现';
                defaultInternal = '身份揭露后两人的信任如何重建';
            } else if (isRevenge) {
                defaultExternal = '复仇计划何时收网/幕后黑手何时现身';
                defaultInternal = '复仇成功后主角内心的空虚如何填补';
            } else if (isCinderella) {
                defaultExternal = '平凡女主角何时让所有人刮目相看';
                defaultInternal = '女主角何时相信自己配得上男主角';
            } else {
                defaultExternal = '男女主角何时打破身份悬殊真正走到一起';
                defaultInternal = '男主角何时放下骄傲真诚表白，女主角何时不再自卑';
            }

            // 保守修复：确保梗概不等于概念
            let finalSynopsis = idea.synopsis;
            if (!finalSynopsis || finalSynopsis.trim().length < 50) {
                // 如果梗概太短或为空，使用默认创意的梗概
                const defaultIdeas = this.getDefaultCreativeIdeas();
                finalSynopsis = defaultIdeas[index % defaultIdeas.length].synopsis;
            }

            return {
                id: `idea-ai-${Date.now()}-${index}`, // 生成唯一ID
                title: idea.title || 'Untitled Creative Idea',
                concept: idea.concept || idea.title || 'No concept provided',
                synopsis: finalSynopsis,
                externalHook: idea.externalHook || idea.hook || defaultExternal,
                internalHook: idea.internalHook || defaultInternal,
                hook: idea.externalHook || idea.hook || defaultExternal, // 兼容旧字段
                highlights: ['AI生成'],
                isCustom: false,
                type: 'AI生成'
            };
        });

        console.log(`[AI服务] 解析完成，有效创意数量: ${validIdeas.length}`);
        validIdeas.forEach((idea, i) => {
            console.log(`[AI服务] 创意${i+1}: ${idea.title.substring(0, 50)}...`);
        });

        // 如果创意不足5个，使用模板补齐
        if (validIdeas.length < 5) {
            console.warn(`[AI服务] 创意不足5个(${validIdeas.length}个)，使用默认模板补齐`);
            const defaultIdeas = this.getDefaultCreativeIdeas();
            while (validIdeas.length < 5) {
                const defaultIdea = defaultIdeas[validIdeas.length];
                validIdeas.push({
                    ...defaultIdea,
                    id: `idea-default-${Date.now()}-${validIdeas.length}` // 确保唯一ID
                });
            }
        }

        return validIdeas;
    }

