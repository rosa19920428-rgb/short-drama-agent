    /**
     * 解析AI返回的标题内容
     */
    parseTitles(content) {
        const titles = [];

        // 尝试匹配 "1. Title" 或 "1. Title\n   Subtitle" 格式
        const titleRegex = /^\d+[\.\、]\s*(.+?)(?:\n|$)(?:\s*(.+?)(?=\n\d+[\.\、]|$))?/gms;

        let match;
        while ((match = titleRegex.exec(content)) !== null) {
            const mainTitle = match[1]?.trim() || '';
            const subTitle = match[2]?.trim() || '';

            if (mainTitle) {
                titles.push({
                    main: mainTitle,
                    sub: subTitle
                });
            }
        }

        // 如果上面的正则没有匹配到，尝试简单的分行解析
        if (titles.length === 0) {
            const lines = content.split('\n').filter(line => line.trim());
            let currentTitle = null;

            for (const line of lines) {
                const trimmedLine = line.trim();

                // 检查是否是新的标题开始（包含数字或点号）
                if (/^\d+[\.\、]/.test(trimmedLine)) {
                    if (currentTitle) {
                        titles.push(currentTitle);
                    }

                    const titleText = trimmedLine.replace(/^\d+[\.\、]\s*/, '').trim();
                    currentTitle = {
                        main: titleText,
                        sub: ''
                    };
                } else if (currentTitle && !currentTitle.sub) {
                    // 可能是副标题
                    currentTitle.sub = trimmedLine;
                }
            }

            if (currentTitle) {
                titles.push(currentTitle);
            }
        }

        return titles;
    }

