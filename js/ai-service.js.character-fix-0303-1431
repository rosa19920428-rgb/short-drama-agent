            })
        });

        if (!response.ok) {
            throw new Error(`Failed to generate episode ${episode.episodeNumber}`);
        }

        const data = await response.json();
        let scriptContent = data.choices[0].message.content;

        // 后处理：确保使用正确的角色名字
        scriptContent = this.enforceCharacterNames(scriptContent, characters);

        return {
            episodeNumber: episode.episodeNumber,
