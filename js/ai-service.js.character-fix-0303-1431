    /**
     * 解析批量生成的大纲
     */
    parseBatchOutline(aiText, startEp, endEp) {
        const episodes = [];
        const lines = aiText.split('\n').filter(line => line.trim());

        let currentEpisode = null;
        let currentEpNumber = null;

        for (const line of lines) {
            // 匹配集数标题：第X集：《标题》或第X集 或 Episode X
            const episodeMatch = line.match(/第\s*(\d+)\s*集[:：]\s*《?([^》]+)》?/) ||
                                 line.match(/Episode\s+(\d+)[:\-\s]+["《]?([^"》]+)["》]?/i);

            if (episodeMatch) {
                // 保存上一集
                if (currentEpisode && currentEpNumber !== null) {
                    episodes.push(currentEpisode);
                }

                currentEpNumber = parseInt(episodeMatch[1]);
                currentEpisode = {
                    episodeNumber: currentEpNumber,
                    title: episodeMatch[2]?.trim() || `第${currentEpNumber}集`,
                    content: '',
                    hook: '',
                    act: this.getActByEpisode(currentEpNumber, endEp),
                    isTwist: false,
                    isClimax: currentEpNumber === endEp,
                    isFirst: currentEpNumber === 1,
                    isFinal: currentEpNumber === endEp,
                    estimatedDuration: 90
                };
            } else if (currentEpisode) {
                // 解析其他字段
                const lowerLine = line.toLowerCase();

                if (lowerLine.includes('剧情') || lowerLine.includes('plot')) {
                    currentEpisode.content += line.replace(/.*[:：]/, '').trim() + '\n';
                } else if (lowerLine.includes('钩子') || lowerLine.includes('hook')) {
                    currentEpisode.hook = line.replace(/.*[:：]/, '').trim();
                } else if (lowerLine.includes('爽点') || lowerLine.includes('反转') || lowerLine.includes('twist')) {
                    currentEpisode.content += '【' + line.trim() + '】\n';
                } else if (lowerLine.includes('场景') || lowerLine.includes('setting')) {
                    currentEpisode.content += '[场景: ' + line.replace(/.*[:：]/, '').trim() + ']\n';
                } else if (lowerLine.includes('时长') || lowerLine.includes('duration')) {
                    const duration = line.match(/(\d+)/);
                    if (duration) {
                        currentEpisode.estimatedDuration = parseInt(duration[1]);
                    }
                } else {
                    currentEpisode.content += line + '\n';
                }
            }
        }

        // 添加最后一集
        if (currentEpisode && currentEpNumber !== null) {
            episodes.push(currentEpisode);
        }

        // 标记反转集
        episodes.forEach((ep, index) => {
            if (index > 0 && index < episodes.length - 1) {
                if (ep.content.includes('反转') || ep.content.includes('真相') ||
                    ep.content.toLowerCase().includes('twist') || ep.content.toLowerCase().includes('reveal')) {
                    ep.isTwist = true;
                }
            }
        });

        // 检查是否生成了足够的集数
        const expectedCount = endEp - startEp + 1;
        if (episodes.length < expectedCount) {
            console.warn(`批次生成不足: 期望${expectedCount}集, 实际${episodes.length}集`);
            // 补充缺失的集数
            for (let i = startEp; i <= endEp; i++) {
                if (!episodes.find(ep => ep.episodeNumber === i)) {
                    episodes.push({
                        episodeNumber: i,
                        title: `第${i}集`,
                        content: '[该集内容缺失，请重新生成本批次]',
                        hook: 'To be continued...',
                        act: this.getActByEpisode(i, endEp),
                        isTwist: false,
                        isClimax: i === endEp,
                        isFirst: i === 1,
                        isFinal: i === endEp,
                        estimatedDuration: 90
                    });
                }
            }
        }

        // 按集数排序
        return episodes.sort((a, b) => a.episodeNumber - b.episodeNumber);
    }

